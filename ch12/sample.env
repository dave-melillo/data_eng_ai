# Chapter 12 Environment Variables
# Copy this file to .env and fill in your API keys:  cp sample.env .env

# Required for the extraction and ranking agents
OPENAI_API_KEY=your_openai_api_key_here

# Required for the URL discovery agent (Listing 12.3)
SERPAPI_KEY=your_serpapi_key_here

# Load in your notebook:
#   from dotenv import load_dotenv; load_dotenv()
# Or export before launching Jupyter:
#   export OPENAI_API_KEY="..."
#   export SERPAPI_KEY="..."

# API key sources:
# - OpenAI:  https://platform.openai.com/api-keys
# - SerpAPI: https://serpapi.com  (free tier: 100 searches/month)
#
# No SerpAPI key? See setup/chapter_12_setup.md to supply URLs manually.
